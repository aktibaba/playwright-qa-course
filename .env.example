# dev.to API key — create one at https://dev.to/settings/extensions ("DEV Community API Keys").
# Used by `npm run blog:devto` to push chapters as DRAFTS (you review & publish on dev.to).
DEV_API_KEY=your_devto_api_key_here

# Optional: canonical base URL for your own site, used to set canonical_url on dev.to
# so search engines credit your site as the original. Leave blank to skip.
SITE_BASE_URL=
